# ─── Servidor ───
PORT=4000
NODE_ENV=development

# ─── JWT ───
# Cambia esto por una clave segura en producción
JWT_SECRET=plop-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── PostgreSQL (Supabase) ───
# Ve a Supabase > Project > Settings > Database > Connection string (URI)
# Formato: postgresql://user:password@host:port/database
PG_HOST=aws-0-region.pooler.supabase.com
PG_PORT=5432
PG_USERNAME=postgres
PG_PASSWORD=your-supabase-password
PG_DATABASE=postgres

# ─── MongoDB (Atlas) ───
# Ve a MongoDB Atlas > Database > Connect > Drivers > Connection string
# Formato: mongodb+srv://user:password@cluster.xxxxx.mongodb.net/plop
MONGO_URI=mongodb+srv://user:password@cluster.xxxxx.mongodb.net/plop

# ─── CORS ───
# URLs del frontend (separadas por coma si hay varias)
CORS_ORIGIN=http://localhost:3000,https://tu-app.vercel.app

# ─── Uploads ───
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
